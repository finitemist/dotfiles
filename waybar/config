{
  "layer": "top",
  "position": "top",
  "height": 38,
  "margin-top": 5,
  "margin-left": 10,
  "margin-right": 10,
  "spacing": 2,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "pulseaudio", "battery", "cpu", "memory", "custom/language", "tray"],

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": " ",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "custom/language": {
    "exec": "$HOME/.config/waybar/get_language.sh",
    "return-type": "json",
    "on-click": "hyprctl switchxkblayout all next",
    "format": "{}"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "active": "󰮯",
      "default": "󰑊",
      "empty": "󰑊",
      "5": "󰊠",
      "10": "󰊠"
    },
    "persistent-workspaces": {
      "eDP-1": [1, 2, 3, 4, 5],
      "HDMI-A-1": [6, 7, 8, 9, 10]
    }
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}"
  },

  "network": {
    "format-wifi": "",
    "format-ethernet": "󰈀",
    "format-disconnected": "",
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["", "", "", "", ""]
  },

  "cpu": {
    "format": " {usage}%"
  },

  "memory": {
    "format": " {used}GB"
  },

  "tray": {
    "icon-size": 12,
    "spacing": 1
  }
}
